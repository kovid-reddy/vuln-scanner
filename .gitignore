# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules
.pnpm-store

# ── Environment files (NEVER commit these) ───────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
apps/api/.env
apps/web/.env.local
apps/web/.env.production
# Allow .env.example files (templates without real secrets)
!.env.example
!**/.env.example

# ── Build outputs ─────────────────────────────────────────────────────────────
dist
build
.next
out

# Safety net: prevent compiled tsc output from leaking into src/ directories
# (this happens if tsc is accidentally run without outDir: "dist" configured)
apps/scanner/src/**/*.js
apps/scanner/src/**/*.js.map
apps/scanner/src/**/*.d.ts
!apps/scanner/src/cheerio.d.ts
packages/shared-types/src/*.js
packages/shared-types/src/*.js.map
packages/shared-types/src/*.d.ts

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
*.d.ts.map

# ── Prisma ────────────────────────────────────────────────────────────────────
# Keep schema.prisma and migrations — ignore only the generated client
apps/api/node_modules/.prisma
apps/api/prisma/migrations/migration_lock.toml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
.pnpm-debug.log*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history

# ── Testing ───────────────────────────────────────────────────────────────────
coverage
.nyc_output
*.lcov

# ── Turbo ─────────────────────────────────────────────────────────────────────
.turbo

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't ignore Dockerfiles — Railway/Render needs them
# DO ignore any local docker volumes or overrides
docker-compose.override.yml
docker-compose.local.yml
.docker

# ── Scanner specific ──────────────────────────────────────────────────────────
*.scan.json
scan-results/

# ── Misc ──────────────────────────────────────────────────────────────────────
.cache
tmp/
temp/
.temp
.tmp
*.bak
*.backup