{
  "name": "api",
  "version": "1.0.0",
  "scripts": {
    "postinstall":   "prisma generate",
    "dev":           "tsx watch src/server.ts",
    "worker":        "tsx watch src/queue/scan.worker.ts",
    "start":         "node --loader tsx/esm src/server.ts",
    "start:worker":  "node --loader tsx/esm src/queue/scan.worker.ts",
    "build":         "tsc",
    "db:migrate":    "prisma migrate dev",
    "db:deploy":     "prisma migrate deploy",
    "db:generate":   "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^5.0.0",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.0",
    "ioredis": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}